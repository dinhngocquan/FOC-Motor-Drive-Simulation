<?xml version="1.0" encoding="utf-8"?>
<System>
  <P Name="Location">[-1, -7, 1537, 817]</P>
  <P Name="ZoomFactor">200</P>
  <Block BlockType="Inport" Name="Id" SID="1744">
    <P Name="Position">[320, 38, 350, 52]</P>
    <P Name="ZOrder">-1</P>
    <P Name="BlockMirror">on</P>
  </Block>
  <Block BlockType="SubSystem" Name="Discrete Tranfer Function1" SID="1745">
    <PortCounts in="1" out="1"/>
    <P Name="Position">[100, 20, 170, 70]</P>
    <P Name="ZOrder">-2</P>
    <P Name="BlockMirror">on</P>
    <Mask>
      <Type>First Order Low Pass Filter (Discrete)</Type>
      <Display>plot(X,Y);
disp(str);
</Display>
      <Description>H(s)=1/(1+T.s)</Description>
      <Initialization> X=[0 1 2 3 4];
 Y=[-2 -2 -3 -4 -4];
 str=sprintf(&apos;\nH=1/(1+T.s)\n T= %g s\n\n\n&apos;,T);
num=1;
den=[T 1];

% discrete transfer function
% descending powers of z
numd= Ts/T;
dend=[ 1  (Ts-T)/T];

</Initialization>
      <MaskParameter Name="T" Type="edit">
        <Prompt>Time constant T (s) :</Prompt>
        <Value>Tr</Value>
      </MaskParameter>
      <MaskParameter Name="Ts" Type="edit">
        <Prompt>Time step (s)</Prompt>
        <Value>Ts</Value>
      </MaskParameter>
    </Mask>
    <System Ref="system_1745"/>
  </Block>
  <Block BlockType="Gain" Name="Lm" SID="1749">
    <P Name="Position">[220, 27, 280, 63]</P>
    <P Name="ZOrder">-3</P>
    <P Name="BlockMirror">on</P>
